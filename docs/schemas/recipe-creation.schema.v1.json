{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recipebook.app/schemas/recipe-creation/v1",
  "title": "RecipeBook Recipe Creation Payload v1",
  "description": "AI-friendly minimal payload for creating a single bilingual recipe with structured ingredient lines.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recipe"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "recipe-creation/v1"
    },
    "recipe": {
      "$ref": "#/$defs/RecipeCreation"
    }
  },
  "$defs": {
    "Uuid": {
      "type": "string",
      "format": "uuid"
    },
    "DateTime": {
      "type": "string",
      "format": "date-time"
    },
    "LanguageTextRequired": {
      "type": "object",
      "description": "System-defined recipe text fields must exist in both languages, even if empty strings.",
      "additionalProperties": false,
      "required": ["title", "description", "instructions", "notes"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructions": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "LanguagesRequired": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fr", "en"],
      "properties": {
        "fr": { "$ref": "#/$defs/LanguageTextRequired" },
        "en": { "$ref": "#/$defs/LanguageTextRequired" }
      }
    },
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceUrl", "sourceName"],
      "properties": {
        "sourceUrl": { "type": "string", "format": "uri" },
        "sourceName": { "type": "string" }
      }
    },
    "IngredientLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "originalText", "ingredientName"],
      "properties": {
        "id": { "$ref": "#/$defs/Uuid" },
        "ingredientRefId": { "$ref": "#/$defs/Uuid" },
        "originalText": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string", "description": "Canonical unit id (for example g, ml, tsp, cup)." },
        "ingredientName": { "type": "string" },
        "preparation": { "type": "string" },
        "optional": { "type": "boolean", "default": false },
        "notes": { "type": "string" },
        "group": { "type": "string" },
        "substitutions": {
          "type": "array",
          "items": { "$ref": "#/$defs/IngredientLineSubstitution" }
        }
      }
    },
    "IngredientLineSubstitution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "ingredientLineId", "createdAt", "updatedAt"],
      "properties": {
        "id": { "$ref": "#/$defs/Uuid" },
        "ingredientLineId": { "$ref": "#/$defs/Uuid" },
        "substitutionRuleId": { "$ref": "#/$defs/Uuid" },
        "contextualSubstitutionRuleId": { "$ref": "#/$defs/Uuid" },
        "isPreferred": { "type": "boolean", "default": false },
        "customLabelFr": { "type": "string" },
        "customLabelEn": { "type": "string" },
        "createdAt": { "$ref": "#/$defs/DateTime" },
        "updatedAt": { "$ref": "#/$defs/DateTime" }
      },
      "anyOf": [
        { "required": ["substitutionRuleId"] },
        { "required": ["contextualSubstitutionRuleId"] }
      ]
    },
    "Servings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount"],
      "properties": {
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "type": "string" }
      }
    },
    "Times": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prepTimeMinutes": { "type": "integer", "minimum": 0 },
        "cookTimeMinutes": { "type": "integer", "minimum": 0 },
        "totalTimeMinutes": { "type": "integer", "minimum": 0 }
      }
    },
    "RecipeCreation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "createdAt", "updatedAt", "languages", "ingredients"],
      "properties": {
        "id": { "$ref": "#/$defs/Uuid" },
        "createdAt": { "$ref": "#/$defs/DateTime" },
        "updatedAt": { "$ref": "#/$defs/DateTime" },
        "source": { "$ref": "#/$defs/Source" },
        "languages": { "$ref": "#/$defs/LanguagesRequired" },
        "ingredients": {
          "type": "array",
          "items": { "$ref": "#/$defs/IngredientLine" }
        },
        "servings": { "$ref": "#/$defs/Servings" },
        "times": { "$ref": "#/$defs/Times" },
        "tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/Uuid" }
        },
        "collections": {
          "type": "array",
          "items": { "$ref": "#/$defs/Uuid" }
        },
        "ratings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "userRating": { "type": "number", "minimum": 0, "maximum": 5 },
            "madeCount": { "type": "integer", "minimum": 0 },
            "lastMadeAt": { "$ref": "#/$defs/DateTime" }
          }
        },
        "mainPhotoId": { "$ref": "#/$defs/Uuid" },
        "photos": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "relativePath"],
            "properties": {
              "id": { "$ref": "#/$defs/Uuid" },
              "relativePath": { "type": "string", "description": "Package-relative media path inside an export bundle, for example photos/abc.jpg." },
              "cloudRef": { "type": "string" }
            }
          }
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "fileName", "mimeType", "relativePath"],
            "properties": {
              "id": { "$ref": "#/$defs/Uuid" },
              "fileName": { "type": "string" },
              "mimeType": { "type": "string" },
              "relativePath": { "type": "string", "description": "Package-relative media path inside an export bundle, for example attachments/abc.pdf." }
            }
          }
        },
        "importMetadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sourceType": { "type": "string" },
            "parserVersion": { "type": "string" },
            "originalUnits": { "type": "string" }
          }
        }
      }
    }
  },
  "examples": [
    {
      "schemaVersion": "recipe-creation/v1",
      "recipe": {
        "id": "9340cc85-dbcf-4b7d-92ed-574e6c8fbf3d",
        "createdAt": "2026-03-02T12:00:00Z",
        "updatedAt": "2026-03-02T12:00:00Z",
        "languages": {
          "fr": {
            "title": "Pancakes classiques",
            "description": "Pancakes rapides et moelleux.",
            "instructions": "Melanger puis cuire dans une poele chaude.",
            "notes": ""
          },
          "en": {
            "title": "Classic pancakes",
            "description": "Quick fluffy pancakes.",
            "instructions": "Mix and cook in a hot pan.",
            "notes": ""
          }
        },
        "ingredients": [
          {
            "id": "2f3287f5-a90e-4e2d-b3ca-1bded383a4c2",
            "originalText": "200 g flour",
            "quantity": 200,
            "unit": "g",
            "ingredientName": "flour"
          }
        ],
        "servings": {
          "amount": 4
        }
      }
    }
  ]
}



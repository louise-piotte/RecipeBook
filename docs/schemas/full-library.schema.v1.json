{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recipebook.app/schemas/full-library/v1",
  "title": "RecipeBook Full Library v1",
  "description": "Canonical, lossless library payload for local persistence, export/import, and cloud sync.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "library"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "full-library/v1"
    },
    "library": {
      "$ref": "#/$defs/Library"
    }
  },
  "$defs": {
    "Uuid": {
      "type": "string",
      "format": "uuid"
    },
    "DateTime": {
      "type": "string",
      "format": "date-time"
    },
    "LanguageTextRequired": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "preparationSteps",
        "instructions",
        "notesSystem"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "preparationSteps": {
          "type": "string"
        },
        "instructions": {
          "type": "string"
        },
        "notesSystem": {
          "type": "string"
        }
      }
    },
    "LanguagesRequired": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fr",
        "en"
      ],
      "properties": {
        "fr": {
          "$ref": "#/$defs/LanguageTextRequired"
        },
        "en": {
          "$ref": "#/$defs/LanguageTextRequired"
        }
      }
    },
    "UserNotes": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "fr": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      }
    },
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceUrl",
        "sourceName"
      ],
      "properties": {
        "sourceUrl": {
          "type": "string",
          "format": "uri"
        },
        "sourceName": {
          "type": "string"
        }
      }
    },
    "IngredientLine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "originalText",
        "ingredientName"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Uuid"
        },
        "ingredientRefId": {
          "$ref": "#/$defs/Uuid"
        },
        "originalText": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "ingredientName": {
          "type": "string"
        },
        "preparation": {
          "type": "string"
        },
        "optional": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string"
        },
        "group": {
          "type": "string"
        }
      }
    },
    "Servings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount"
      ],
      "properties": {
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit": {
          "type": "string"
        }
      }
    },
    "Times": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prepTimeMinutes": {
          "type": "integer",
          "minimum": 0
        },
        "cookTimeMinutes": {
          "type": "integer",
          "minimum": 0
        },
        "totalTimeMinutes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Ratings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "userRating": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "madeCount": {
          "type": "integer",
          "minimum": 0
        },
        "lastMadeAt": {
          "$ref": "#/$defs/DateTime"
        }
      }
    },
    "PhotoRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "localPath"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Uuid"
        },
        "localPath": {
          "type": "string"
        },
        "cloudRef": {
          "type": "string"
        }
      }
    },
    "AttachmentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fileName",
        "mimeType",
        "localPath"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Uuid"
        },
        "fileName": {
          "type": "string"
        },
        "mimeType": {
          "type": "string"
        },
        "localPath": {
          "type": "string"
        },
        "cloudRef": {
          "type": "string"
        }
      }
    },
    "ImportMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceType": {
          "type": "string"
        },
        "parserVersion": {
          "type": "string"
        },
        "originalUnits": {
          "type": "string"
        }
      }
    },
    "Recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "createdAt",
        "updatedAt",
        "languages",
        "ingredients",
        "tags",
        "collections",
        "photos",
        "attachments"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Uuid"
        },
        "createdAt": {
          "$ref": "#/$defs/DateTime"
        },
        "updatedAt": {
          "$ref": "#/$defs/DateTime"
        },
        "source": {
          "$ref": "#/$defs/Source"
        },
        "languages": {
          "$ref": "#/$defs/LanguagesRequired"
        },
        "userNotes": {
          "$ref": "#/$defs/UserNotes"
        },
        "ingredients": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IngredientLine"
          }
        },
        "servings": {
          "$ref": "#/$defs/Servings"
        },
        "times": {
          "$ref": "#/$defs/Times"
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Uuid"
          }
        },
        "collections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Uuid"
          }
        },
        "ratings": {
          "$ref": "#/$defs/Ratings"
        },
        "photos": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PhotoRef"
          }
        },
        "attachments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AttachmentRef"
          }
        },
        "importMetadata": {
          "$ref": "#/$defs/ImportMetadata"
        },
        "deletedAt": {
          "$ref": "#/$defs/DateTime"
        }
      }
    },
    "IngredientReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "nameFr",
        "nameEn",
        "aliasesFr",
        "aliasesEn",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Uuid"
        },
        "nameFr": {
          "type": "string"
        },
        "nameEn": {
          "type": "string"
        },
        "aliasesFr": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "aliasesEn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "defaultDensity": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Density in g/ml when meaningful."
        },
        "unitMappings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "fromUnit",
              "toUnit",
              "factor"
            ],
            "properties": {
              "fromUnit": {
                "type": "string"
              },
              "toUnit": {
                "type": "string"
              },
              "factor": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          }
        },
        "updatedAt": {
          "$ref": "#/$defs/DateTime"
        }
      }
    },
    "Unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unitId",
        "symbol",
        "nameFr",
        "nameEn",
        "type",
        "toBaseFactor"
      ],
      "properties": {
        "unitId": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "nameFr": {
          "type": "string"
        },
        "nameEn": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "mass",
            "volume",
            "count",
            "length",
            "temperature",
            "other"
          ]
        },
        "baseUnitId": {
          "type": "string",
          "description": "Base unit within the same type (for example g for mass, ml for volume)."
        },
        "toBaseFactor": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "Tag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "nameFr",
        "nameEn",
        "slug"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Uuid"
        },
        "nameFr": {
          "type": "string"
        },
        "nameEn": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        }
      }
    },
    "Collection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "nameFr",
        "nameEn",
        "recipeIds"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/Uuid"
        },
        "nameFr": {
          "type": "string"
        },
        "nameEn": {
          "type": "string"
        },
        "descriptionFr": {
          "type": "string"
        },
        "descriptionEn": {
          "type": "string"
        },
        "recipeIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Uuid"
          }
        },
        "sortOrder": {
          "type": "string",
          "enum": [
            "manual",
            "title_asc",
            "title_desc",
            "rating_desc",
            "recent_desc"
          ]
        }
      }
    },
    "Settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "driveSyncEnabled"
      ],
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "fr",
            "en"
          ]
        },
        "driveSyncEnabled": {
          "type": "boolean"
        },
        "driveFileName": {
          "type": "string"
        },
        "driveFolderId": {
          "type": "string"
        },
        "openSourceInAppBrowser": {
          "type": "boolean"
        }
      }
    },
    "LibraryMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "libraryId",
        "createdAt",
        "updatedAt",
        "exportedAt"
      ],
      "properties": {
        "libraryId": {
          "$ref": "#/$defs/Uuid"
        },
        "createdAt": {
          "$ref": "#/$defs/DateTime"
        },
        "updatedAt": {
          "$ref": "#/$defs/DateTime"
        },
        "exportedAt": {
          "$ref": "#/$defs/DateTime"
        },
        "appVersion": {
          "type": "string"
        },
        "deviceId": {
          "type": "string"
        }
      }
    },
    "Library": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata",
        "recipes",
        "ingredientReferences",
        "units",
        "tags",
        "collections",
        "settings"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/$defs/LibraryMetadata"
        },
        "recipes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Recipe"
          }
        },
        "ingredientReferences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IngredientReference"
          }
        },
        "units": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Unit"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Tag"
          }
        },
        "collections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Collection"
          }
        },
        "settings": {
          "$ref": "#/$defs/Settings"
        }
      }
    }
  },
  "examples": [
    {
      "schemaVersion": "full-library/v1",
      "library": {
        "metadata": {
          "libraryId": "db6aba6f-9f3f-4581-95e6-d7480eb634d4",
          "createdAt": "2026-03-02T12:00:00Z",
          "updatedAt": "2026-03-02T12:00:00Z",
          "exportedAt": "2026-03-02T12:00:00Z",
          "appVersion": "0.1.0"
        },
        "recipes": [],
        "ingredientReferences": [],
        "units": [],
        "tags": [],
        "collections": [],
        "settings": {
          "language": "en",
          "driveSyncEnabled": false
        }
      }
    }
  ]
}

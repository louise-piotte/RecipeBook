  "languages": {
    "fr": {
      "title": "Tarte aux bleuets",
      "description": "Une petite tarte aux bleuets avec une garniture citronn\u00e9e sous une cro\u00fbte du dessus.",
      "instructions": "Pr\u00e9chauffer le four \u00e0 205\u00b0C/400\u00b0F.\nDans un bol, m\u00e9langer les bleuets, le zeste et le jus de citron, le sucre, la f\u00e9cule de ma\u00efs et le sel.\nVerser la garniture dans une cro\u00fbte \u00e0 tarte crue de 5 po. Recouvrir avec l'exc\u00e9dent de p\u00e2te, puis faire quelques ouvertures sur le dessus.\nCuire 40 min, jusqu'\u00e0 ce que la cro\u00fbte soit dor\u00e9e et que la garniture bouillonne.",
      "notes": "Multiplier la garniture par 4 pour faire une tarte de 9 po."
    },
    "en": {
      "title": "Blueberry Pie",
      "description": "A small blueberry pie with a lemony filling tucked under a top crust.",
      "instructions": "Preheat the oven to 205\u00b0C/400\u00b0F.\nIn a bowl, combine the blueberries, lemon zest and juice, sugar, cornstarch, and salt.\nTransfer the filling to a raw 5-inch pie shell. Cover with the extra dough, then cut a few vents in the top.\nBake for 40 min, until the crust is golden and the filling is bubbling.",
      "notes": "Multiply the filling by 4 to make a 9-inch pie."
    }

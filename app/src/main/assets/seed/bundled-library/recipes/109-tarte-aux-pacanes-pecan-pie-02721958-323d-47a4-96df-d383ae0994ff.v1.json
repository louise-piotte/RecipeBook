  "languages": {
    "fr": {
      "title": "Tarte aux pacanes",
      "description": "Une petite tarte aux pacanes avec une garniture au sirop de ma\u00efs et \u00e0 la vanille.",
      "instructions": "Pr\u00e9chauffer le four \u00e0 205\u00b0C/400\u00b0F.\nDans un bol, fouetter le sirop de ma\u00efs, le sucre, l'\u0153uf, le beurre fondu, la vanille et le sel jusqu'\u00e0 homog\u00e9n\u00e9it\u00e9.\nR\u00e9partir les pacanes dans une cro\u00fbte \u00e0 tarte crue de 5 po, puis verser la garniture par-dessus.\nCuire 40 min, jusqu'\u00e0 ce que la garniture soit prise et que la cro\u00fbte soit bien dor\u00e9e.",
      "notes": "Multiplier la recette par 3 pour faire une tarte de 9 po."
    },
    "en": {
      "title": "Pecan Pie",
      "description": "A small pecan pie with a vanilla-scented corn syrup filling.",
      "instructions": "Preheat the oven to 205\u00b0C/400\u00b0F.\nIn a bowl, whisk together the corn syrup, sugar, egg, melted butter, vanilla, and salt until combined.\nScatter the pecans in a raw 5-inch pie shell, then pour the filling over top.\nBake for 40 min, until the filling is set and the crust is well browned.",
      "notes": "Multiply the recipe by 3 to make a 9-inch pie."
    }
  },
